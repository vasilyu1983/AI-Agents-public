{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude-code-kit/skill-dependencies-schema.json",
  "title": "Skill Dependencies Schema",
  "description": "Schema for skill-dependencies.json (skill graph used to generate Related Skills sections).",
  "type": "object",
  "required": ["metadata", "domains", "dependencies"],
  "properties": {
    "$schema": { "type": "string" },
    "metadata": {
      "type": "object",
      "required": ["description", "updated", "total_skills", "version"],
      "properties": {
        "description": { "type": "string", "minLength": 10, "maxLength": 500 },
        "updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "total_skills": { "type": "integer", "minimum": 1 },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+$" }
      },
      "additionalProperties": true
    },
    "domains": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["description", "skills"],
        "properties": {
          "description": { "type": "string", "minLength": 3, "maxLength": 200 },
          "skills": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$" }
          }
        },
        "additionalProperties": true
      }
    },
    "dependencies": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["primary"],
        "properties": {
          "primary": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$" }
          },
          "secondary": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$" }
          },
          "description_map": {
            "type": "object",
            "additionalProperties": { "type": "string", "minLength": 3, "maxLength": 200 }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
